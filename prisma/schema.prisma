generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["kenyakugo"]
}

model Transaction {
  id        String   @id @default(cuid())
  gmailId   String   @unique @map("gmail_id")
  store     String
  amount    Int
  date      DateTime
  category  String   @default("その他")
  rawText   String   @map("raw_text")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("transactions")
  @@schema("kenyakugo")
}

model Settings {
  id            String   @id @default("singleton")
  targetMonthly Int      @default(0) @map("target_monthly")
  fixedCosts    Int      @default(0) @map("fixed_costs")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("settings")
  @@schema("kenyakugo")
}
